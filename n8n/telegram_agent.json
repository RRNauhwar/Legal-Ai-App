    {
      "parameters": {
        "promptType": "define",
        "text": "={{$json.message.text}}",
        "systemMessage": "You are the NyayaSim AI Legal Assistant. You help users manage their mock trial courtroom app via Telegram. You can query their practice stats, fetch the leaderboard, browse cases, generate new cases, and write forum posts.\n\nAlways identify the user by the sender's Telegram User ID: {{$json.message.from.id}} and Name: {{$json.message.from.first_name}}. Use the tools provided to query the NyayaSim API. Format your answers in a professional, legal-themed tone with emojis where appropriate."
      },
      "id": "b9ebcb8a-a22a-4310-a292-628d689b6b00",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1,
      "position": [
        600,
        240
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "c1f7bd8f-09e8-466d-961f-4b0e35fd7d00",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [
        550,
        420
      ],
      "credentials": {
        "openAiApi": {
          "id": "openai-key-id",
          "name": "OpenAI Credentials"
        }
      }
    },
    {
      "parameters": {
        "name": "get_my_stats",
        "description": "Get mock trial win ratio, completed trials, and earned ranking badges for the active user.",
        "url": "={{$env.BACKEND_URL || 'http://localhost:3001'}}/api/stats/me",
        "sendHeaders": true,
        "headersUi": {
          "parameter": [
            {
              "name": "X-Demo-User-Id",
              "value": "={{$node[\"Telegram Trigger\"].json.message.from.id}}"
            },
            {
              "name": "X-Demo-User-Name",
              "value": "={{$node[\"Telegram Trigger\"].json.message.from.first_name}}"
            }
          ]
        }
      },
      "id": "d1a8ce8b-2401-44eb-9d10-85f02bc0f100",
