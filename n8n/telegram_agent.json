    {
      "parameters": {
        "name": "generate_case",
        "description": "Generate a new AI case file brief. Requires parameters 'caseType' (e.g. 'criminal', 'civil', 'constitutional') and 'difficulty' (e.g. 'beginner', 'intermediate', 'advanced').",
        "method": "POST",
        "url": "={{$env.BACKEND_URL || 'http://localhost:3001'}}/api/ai/generate-case",
        "sendBody": true,
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "caseType",
              "value": "={{$json.caseType}}"
            },
            {
              "name": "difficulty",
              "value": "={{$json.difficulty}}"
            }
          ]
        }
      },
      "id": "a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d",
      "name": "Generate Case Tool",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1,
      "position": [
        1140,
        420
      ]
    },
    {
      "parameters": {
        "name": "create_forum_post",
        "description": "Create a new community forum post. Requires parameters 'title' and 'content'. Optionally accepts 'category' (e.g. 'discussion', 'group', 'challenge').",
        "method": "POST",
        "url": "={{$env.BACKEND_URL || 'http://localhost:3001'}}/api/community/posts",
        "sendHeaders": true,
        "headersUi": {
          "parameter": [
            {
              "name": "X-Demo-User-Id",
              "value": "={{$node[\"Telegram Trigger\"].json.message.from.id}}"
            },
            {
              "name": "X-Demo-User-Name",
              "value": "={{$node[\"Telegram Trigger\"].json.message.from.first_name}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "title",
              "value": "={{$json.title}}"
            },
            {
              "name": "content",
              "value": "={{$json.content}}"
            },
            {
              "name": "category",
              "value": "={{$json.category || 'discussion'}}"
            }
          ]
        }
      },
      "id": "b2c3d4e5-f6a7-8b9c-0d1e-2f3a4b5c6d7e",
