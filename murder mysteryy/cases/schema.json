{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nyayasim.dev/schemas/case.schema.json",
  "title": "NyayaSim Murder Mystery Case",
  "description": "Schema for NyayaSim interactive murder mystery case files. Each case is a self-contained investigation with suspects, evidence, forensics, puzzles, and a verifiable solution.",
  "type": "object",
  "required": [
    "caseInfo",
    "locations",
    "suspects",
    "evidence",
    "forensics",
    "puzzles",
    "timeline",
    "solution",
    "hints"
  ],
  "properties": {
    "caseInfo": {
      "type": "object",
      "description": "Top-level metadata about the case.",
      "required": [
        "id",
        "title",
        "level",
        "synopsis",
        "setting",
        "victim",
        "causeOfDeath",
        "discoveryTime",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique case identifier, e.g. 'case-01-silent-roommate'.",
          "pattern": "^case-\\d{2}-[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "description": "Human-readable case title."
        },
        "level": {
          "type": "integer",
          "description": "Difficulty level (1 = beginner, 5 = expert).",
          "minimum": 1,
          "maximum": 5
        },
        "synopsis": {
          "type": "string",
          "description": "Brief narrative hook shown to the player before starting the case."
        },
        "setting": {
          "type": "object",
          "description": "Where and when the crime takes place.",
          "required": ["city", "locale", "description", "era"],
          "properties": {
            "city": { "type": "string" },
            "locale": { "type": "string" },
            "description": { "type": "string" },
            "era": {
              "type": "string",
              "description": "Time period, e.g. 'contemporary', '1990s'."
            }
          }
        },
        "victim": {
          "type": "object",
          "description": "Details about the murder victim.",
          "required": ["name", "age", "occupation", "personality", "background"],
          "properties": {
            "name": { "type": "string" },
            "age": { "type": "integer", "minimum": 0 },
            "occupation": { "type": "string" },
            "personality": { "type": "string" },
            "background": { "type": "string" },
            "photo": {
              "type": "string",
              "description": "Optional path or URL to victim portrait."
            }
          }
        },
        "causeOfDeath": {
          "type": "string",
          "description": "Medical cause of death as it would appear on the autopsy report."
        },
        "discoveryTime": {
          "type": "string",
          "description": "ISO-like timestamp or narrative description of when the body was found."
        },
        "tags": {
          "type": "array",
          "description": "Thematic tags for filtering and recommendations.",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },

    "locations": {
      "type": "array",
      "description": "Explorable locations in the case. Each location can contain discoverable evidence.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "isCrimeScene",
          "isAccessible",
          "discoverableEvidenceIds",
          "interactiveElements"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique location identifier.",
            "pattern": "^loc-[a-z0-9-]+$"
          },
          "name": { "type": "string" },
          "description": {
            "type": "string",
            "description": "Narrative description shown when the player enters the location."
          },
          "isCrimeScene": { "type": "boolean" },
          "isAccessible": {
            "type": "boolean",
            "description": "Whether the location is immediately accessible or must be unlocked."
          },
          "unlockCondition": {
            "type": "string",
            "description": "What must happen before this location becomes accessible. Null if already accessible."
          },
          "discoverableEvidenceIds": {
            "type": "array",
            "description": "IDs of evidence items that can be found at this location.",
            "items": { "type": "string" }
          },
          "interactiveElements": {
            "type": "array",
            "description": "Clickable / examinable objects in the scene that may or may not yield evidence.",
            "items": {
              "type": "object",
              "required": ["name", "description", "yieldsEvidenceId"],
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "yieldsEvidenceId": {
                  "type": ["string", "null"],
                  "description": "Evidence ID this element reveals, or null if it's atmospheric only."
                }
              }
            }
          },
          "ambiance": {
            "type": "string",
            "description": "Optional atmospheric description (sounds, lighting, smell)."
          }
        }
      }
    },

    "suspects": {
      "type": "array",
      "description": "All persons of interest in the case.",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "age",
          "occupation",
          "relationToVictim",
          "personality",
          "background",
          "motive",
          "alibi",
          "isGuilty",
          "secretKnowledge",
          "dialogueTree"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^suspect-[a-z0-9-]+$"
          },
          "name": { "type": "string" },
          "age": { "type": "integer", "minimum": 0 },
          "occupation": { "type": "string" },
          "relationToVictim": { "type": "string" },
          "personality": {
            "type": "string",
            "description": "Brief personality sketch for AI dialogue generation."
          },
          "background": {
            "type": "string",
            "description": "Detailed backstory and connection to the case."
          },
          "motive": {
            "type": "string",
            "description": "Why this person might have wanted the victim dead."
          },
          "alibi": {
            "type": "object",
            "description": "The suspect's stated alibi and its verifiability.",
            "required": ["stated", "truth", "verifiable"],
            "properties": {
              "stated": {
                "type": "string",
                "description": "What the suspect claims they were doing."
              },
              "truth": {
                "type": "string",
                "description": "What they were actually doing."
              },
              "verifiable": {
                "type": "boolean",
                "description": "Whether the alibi can be independently confirmed or debunked."
              },
              "verificationMethod": {
                "type": "string",
                "description": "How the alibi can be verified or broken."
              }
            }
          },
          "isGuilty": { "type": "boolean" },
          "secretKnowledge": {
            "type": "array",
            "description": "Things this suspect knows but won't volunteer. Can be revealed through interrogation pressure.",
            "items": { "type": "string" }
          },
          "evidenceAgainst": {
            "type": "array",
            "description": "IDs of evidence items that implicate this suspect.",
            "items": { "type": "string" }
          },
          "dialogueTree": {
            "type": "object",
            "description": "Branching dialogue for interrogation. Keys are topic IDs, values are dialogue nodes.",
            "required": ["greeting"],
            "additionalProperties": {
              "type": "object",
              "required": ["playerPrompt", "response"],
              "properties": {
                "playerPrompt": {
                  "type": "string",
                  "description": "What the player says or asks to reach this node."
                },
                "response": {
                  "type": "string",
                  "description": "The suspect's reply."
                },
                "emotion": {
                  "type": "string",
                  "description": "Emotional state during this response.",
                  "enum": [
                    "calm",
                    "nervous",
                    "angry",
                    "defensive",
                    "sad",
                    "evasive",
                    "smug",
                    "fearful",
                    "surprised",
                    "resigned",
                    "cooperative"
                  ]
                },
                "revealsInfo": {
                  "type": "string",
                  "description": "Key information this node reveals to the player."
                },
                "triggersContradiction": {
                  "type": ["string", "null"],
                  "description": "ID of a contradiction this node exposes, if any."
                },
                "requiresEvidence": {
                  "type": ["string", "null"],
                  "description": "Evidence ID the player must have discovered to unlock this dialogue option."
                },
                "followUp": {
                  "type": "array",
                  "description": "Topic IDs the player can navigate to after this node.",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },

    "evidence": {
      "type": "array",
      "description": "All collectible evidence items.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "description",
          "locationId",
          "significance",
          "isRedHerring",
          "linkedSuspectIds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ev-[a-z0-9-]+$"
          },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "description": "Category of evidence.",
            "enum": [
              "physical",
              "digital",
              "documentary",
              "testimonial",
              "forensic",
              "circumstantial"
            ]
          },
          "description": {
            "type": "string",
            "description": "What the player sees / reads when examining this evidence."
          },
          "detailedAnalysis": {
            "type": "string",
            "description": "Deeper analysis available after forensic examination."
          },
          "locationId": {
            "type": "string",
            "description": "ID of the location where this evidence is found."
          },
          "significance": {
            "type": "string",
            "description": "Why this evidence matters to the case."
          },
          "isRedHerring": { "type": "boolean" },
          "linkedSuspectIds": {
            "type": "array",
            "description": "Suspect IDs this evidence connects to.",
            "items": { "type": "string" }
          },
          "contradicts": {
            "type": ["string", "null"],
            "description": "ID of the suspect statement or alibi this evidence disproves."
          },
          "discoveryDifficulty": {
            "type": "string",
            "description": "How hard it is to find this evidence.",
            "enum": ["obvious", "moderate", "hidden", "requires-action"]
          }
        }
      }
    },

    "forensics": {
      "type": "array",
      "description": "Forensic analysis reports that can be requested or unlocked.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "title",
          "summary",
          "findings",
          "conclusion",
          "linkedEvidenceIds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^forensic-[a-z0-9-]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "autopsy",
              "fingerprint",
              "dna",
              "toxicology",
              "ballistics",
              "digital-forensics",
              "trace-evidence",
              "blood-spatter",
              "glass-analysis",
              "document-analysis",
              "phone-records"
            ]
          },
          "title": { "type": "string" },
          "summary": {
            "type": "string",
            "description": "Brief one-line summary of findings."
          },
          "findings": {
            "type": "array",
            "description": "Detailed forensic findings, each as a separate point.",
            "items": { "type": "string" },
            "minItems": 1
          },
          "conclusion": {
            "type": "string",
            "description": "Expert conclusion drawn from the findings."
          },
          "linkedEvidenceIds": {
            "type": "array",
            "description": "Evidence IDs analyzed in this report.",
            "items": { "type": "string" }
          },
          "implicates": {
            "type": ["string", "null"],
            "description": "Suspect ID this forensic report points toward, if any."
          }
        }
      }
    },

    "puzzles": {
      "type": "array",
      "description": "Interactive puzzles the player must solve to unlock evidence or progress.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "description",
          "difficulty",
          "inputData",
          "solution",
          "reward",
          "hints"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^puzzle-[a-z0-9-]+$"
          },
          "title": { "type": "string" },
          "type": {
            "type": "string",
            "description": "Puzzle mechanic type.",
            "enum": [
              "sequence",
              "cipher",
              "code-entry",
              "pattern-match",
              "logic-grid",
              "jigsaw",
              "timeline",
              "word-puzzle"
            ]
          },
          "description": {
            "type": "string",
            "description": "What the player sees as the puzzle prompt."
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "inputData": {
            "type": "object",
            "description": "Puzzle-specific input data. Structure varies by puzzle type.",
            "additionalProperties": true
          },
          "solution": {
            "type": "object",
            "description": "The correct answer and how to verify it.",
            "required": ["answer", "explanation"],
            "properties": {
              "answer": {
                "description": "The correct answer. Can be string, number, or array.",
                "type": ["string", "number", "array"]
              },
              "explanation": {
                "type": "string",
                "description": "How the solution is derived."
              }
            }
          },
          "reward": {
            "type": "object",
            "description": "What the player receives for solving the puzzle.",
            "required": ["type", "id"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["evidence", "location", "dialogue-option", "info"]
              },
              "id": {
                "type": "string",
                "description": "ID of the unlocked resource."
              },
              "narrative": {
                "type": "string",
                "description": "Narrative text shown upon solving."
              }
            }
          },
          "hints": {
            "type": "array",
            "description": "Progressive hints for the puzzle, from vague to specific.",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },

    "timeline": {
      "type": "array",
      "description": "Chronological sequence of events. Includes both known and hidden events.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "time",
          "event",
          "involvedActors",
          "isKnownToPlayer",
          "source"
        ],
        "properties": {
          "time": {
            "type": "string",
            "description": "Timestamp of the event, e.g. '2024-11-11T21:15:00'."
          },
          "event": {
            "type": "string",
            "description": "What happened at this time."
          },
          "involvedActors": {
            "type": "array",
            "description": "IDs of suspects/victim involved.",
            "items": { "type": "string" }
          },
          "isKnownToPlayer": {
            "type": "boolean",
            "description": "Whether this event is initially visible or must be discovered."
          },
          "source": {
            "type": "string",
            "description": "How this event can be established (evidence ID, witness, etc.)."
          },
          "significance": {
            "type": "string",
            "description": "Why this event matters to the investigation."
          }
        }
      }
    },

    "solution": {
      "type": "object",
      "description": "The verified solution to the case. Used to evaluate the player's accusation.",
      "required": [
        "killer",
        "weapon",
        "method",
        "motive",
        "narrative",
        "criticalEvidenceIds",
        "accusationChecklist"
      ],
      "properties": {
        "killer": {
          "type": "string",
          "description": "Suspect ID of the guilty party."
        },
        "weapon": {
          "type": "string",
          "description": "The murder weapon."
        },
        "method": {
          "type": "string",
          "description": "How the murder was committed."
        },
        "motive": {
          "type": "string",
          "description": "Why the killer committed the murder."
        },
        "narrative": {
          "type": "string",
          "description": "Full prose reconstruction of events as they actually happened."
        },
        "criticalEvidenceIds": {
          "type": "array",
          "description": "Evidence IDs the player must cite to get a conviction.",
          "items": { "type": "string" },
          "minItems": 1
        },
        "accusationChecklist": {
          "type": "array",
          "description": "Conditions the player must satisfy for a successful accusation.",
          "items": {
            "type": "object",
            "required": ["requirement", "points"],
            "properties": {
              "requirement": {
                "type": "string",
                "description": "A condition the player must identify."
              },
              "points": {
                "type": "integer",
                "description": "Score awarded for satisfying this condition.",
                "minimum": 0
              }
            }
          }
        }
      }
    },

    "hints": {
      "type": "array",
      "description": "Progressive hint system. Hints are revealed one at a time, from vague to specific.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "text", "cost"],
        "properties": {
          "level": {
            "type": "integer",
            "description": "Hint progression level (1 = gentlest nudge, higher = more revealing).",
            "minimum": 1
          },
          "text": {
            "type": "string",
            "description": "The hint text shown to the player."
          },
          "cost": {
            "type": "integer",
            "description": "Score penalty for using this hint.",
            "minimum": 0
          },
          "category": {
            "type": "string",
            "description": "Which aspect of the case this hint addresses.",
            "enum": [
              "suspect",
              "evidence",
              "motive",
              "method",
              "timeline"
            ]
          }
        }
      }
    }
  }
}
